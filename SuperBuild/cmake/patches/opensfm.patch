index 74e2a797..45118a08 100644
--- a/opensfm/src/cmake/win32/FindCeres.cmake
+++ b/opensfm/src/cmake/win32/FindCeres.cmake
@@ -46,7 +46,7 @@ FIND_LIBRARY(CERES_LIBRARY
 # handle the QUIETLY and REQUIRED arguments and set CERES_FOUND to TRUE if
 # all listed variables are TRUE
 INCLUDE(FindPackageHandleStandardArgs)
-FIND_PACKAGE_HANDLE_STANDARD_ARGS(ceres DEFAULT_MSG
+FIND_PACKAGE_HANDLE_STANDARD_ARGS(Ceres DEFAULT_MSG
     CERES_LIBRARY CERES_INCLUDE_DIR)
 
 IF(CERES_FOUND)
